# Auth mode: local | github | hybrid
AUTH_MODE=hybrid

# GitHub OAuth (required for github/hybrid auth mode)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub repo for DB snapshots (org/repo format)
GITHUB_REPO=
GITHUB_TOKEN=

# Database path
DB_PATH=data/microscape.db

# Origin URL — must exactly match the public URL the browser uses.
# Required for SvelteKit CSRF protection AND for setting Secure on the
# session cookie (Secure is set when ORIGIN starts with https://).
ORIGIN=http://localhost:5173

# Max request body in bytes.
BODY_SIZE_LIMIT=20000000

# Behind nginx, the socket peer address is 127.0.0.1 for every request;
# set these to read the true client IP from X-Forwarded-For. Leave unset
# when running without a proxy (trusting a forgeable header is worse than
# useless).
# ADDRESS_HEADER=X-Forwarded-For
# XFF_DEPTH=1

# Default lab name for the first-run seed. The first boot creates a single
# lab with this name and assigns the seeded admin account to it. Additional
# labs are created via scripts/create-lab.mjs.
DEFAULT_LAB_NAME=microscape

# Root directory under which run data lives on this host. The gated file
# endpoint validates that run.data_path stays inside this root before
# emitting X-Accel-Redirect; nginx's `internal` alias points at the same
# root. Override per environment.
RUNS_ROOT=/data/web/microscape.app

# NOTE: on first startup (users table empty) a seeded `admin/admin` account
# is created. The first login forces a password change before any other
# action. Bootstrap from a private network BEFORE exposing publicly.
